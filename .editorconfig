root = true

[*]
charset = utf-8
[*.cs]
csharp_new_line_before_open_brace = none

dotnet_naming_style.snake_case_style.capitalization = all_lower
dotnet_naming_style.snake_case_style.word_separator = _

dotnet_naming_symbols.private_fields.applicable_kinds = field
dotnet_naming_symbols.private_fields.applicable_accessibilities = private

dotnet_naming_rule.private_fields_snake_case.symbols  = private_fields
dotnet_naming_rule.private_fields_snake_case.style    = snake_case_style
dotnet_naming_rule.private_fields_snake_case.severity = suggestion
